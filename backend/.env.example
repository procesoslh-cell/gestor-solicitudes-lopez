# Backend
PORT=3001
APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3001
DEMO_RESET_ENABLED=false

# Odoo PostgreSQL replica
ODOO_DB_HOST=
ODOO_DB_PORT=5432
ODOO_DB_NAME=
ODOO_DB_USER=
ODOO_DB_PASSWORD=
ODOO_DB_SSL=true

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CC_EMAIL=

# =========================
# Produccion / estabilidad V8
# =========================
NODE_ENV=production
APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173
JSON_BODY_LIMIT=10mb
HTTP_SLOW_LOG_MS=1500
HTTP_REQUEST_TIMEOUT_MS=120000
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000

# Pool de lectura Odoo PostgreSQL
ODOO_DB_POOL_MIN=0
ODOO_DB_POOL_MAX=10
ODOO_DB_IDLE_TIMEOUT_MS=30000
ODOO_DB_CONNECTION_TIMEOUT_MS=8000
ODOO_DB_STATEMENT_TIMEOUT_MS=45000
ODOO_DB_QUERY_TIMEOUT_MS=50000
ODOO_SLOW_QUERY_MS=2500

# Cache liviano para consultas pesadas/repetidas
ODOO_QUERY_CACHE_ENABLED=true
ODOO_QUERY_CACHE_TTL_MS=60000
QUERY_CACHE_MAX_ITEMS=300
PRICE_LIST_CACHE_TTL_MS=300000
PRODUCT_IMAGE_BASE_URL=https://lopezbicipartes.com.ar

# Nota OAuth Microsoft futura
MICROSOFT_AUTH_ENABLED=false
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/callback
